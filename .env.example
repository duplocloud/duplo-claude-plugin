# DuploCloud Claude Plugin — environment variables
# Copy this file to .env and fill in your values.
# Then run: source .env  (or add to your shell profile)

# Bearer token for the duplo-helpdesk MCP server
export DUPLO_TOKEN="your-token-here"

# Base URL of the duplo-helpdesk MCP server
# Remote (test21): https://mcp-ai-studio.test21-apps.duplocloud.net
# Local:           http://localhost:8000
export DUPLO_HELPDESK_URL="https://mcp-ai-studio.test21-apps.duplocloud.net"

# Agent mode — controls who responds to ticket messages.
# true  = Claude / Cursor acts as the agent. Messages are recorded to the ticket
#         The DuploCloud backend AI agent handles responses via Ticket_send_message_streaming.
#         This is the default for production workflows.
# false = Claude/Cursor acts as the local agent. Messages are recorded via message_mode=1
#         (record-only). No backend AI agent is invoked. Use this when you want the AI
#         coding assistant itself to drive the conversation (e.g. Cursor, Claude Code).
export DUPLO_AGENT_MODE="true"
