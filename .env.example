# DuploCloud Claude Plugin — environment variables
# Copy this file to .env and fill in your values.
# Then run: source .env  (or add to your shell profile)

# Bearer token for the duplo-helpdesk MCP server
export DUPLO_TOKEN="your-token-here"

# Base URL of the duplo-helpdesk MCP server
# Remote (test21): https://mcp-ai-studio.test21-apps.duplocloud.net
# Local:           http://localhost:8000
export DUPLO_HELPDESK_URL="https://mcp-ai-studio.test21-apps.duplocloud.net"
